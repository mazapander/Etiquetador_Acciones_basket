DATABASE_URL=sqlite:///./etiquetador.db
# Production format: postgresql+psycopg://USER:PASSWORD@postgres-main:5432/etiquetador
DB_POOL_PRE_PING=true

VIDEO_STORAGE_DIR=/app/storage/videos
VIDEO_LIBRARY_DIR=/app/storage/library
CLIP_EXPORTS_DIR=/app/storage/clip_exports

FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

AUTH_ENABLED=false
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=
ADMIN_EMAILS=[]

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
